# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false

# Google OAuth credentials belong in Supabase, not this file.
# Configure a Web application callback:
# https://YOUR_PROJECT.supabase.co/auth/v1/callback
# Add local redirects:
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/confirm

# Email authentication (server-only)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=<your-smtp-user>
SMTP_PASS=<your-smtp-password>
SMTP_FROM=RoadRunners <noreply@example.com>

# Canonical generation provider (server-only)
CHIKKY_AI_API_KEY=<your-generation-provider-key>
CHIKKY_AI_MODEL=gpt-4.1-mini
CHIKKY_AI_PROVIDER=openai

# Optional native-provider fallback configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Scrim runtime
# browser = local Sandpack/Pyodide development or degraded mode
# daytona = server sandbox
# auto = compatibility mode during the Daytona transition
SCRIM_RUNNER=auto
SCRIM_TTS_ENABLED=true
SCRIM_MAX_CHECKPOINTS=5
SCRIM_MAX_USER_SCRIMS_PER_JOURNEY=20

# Daytona (server-only)
DAYTONA_API_KEY=<your-daytona-api-key>
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us
DAYTONA_DEFAULT_LANGUAGE=python
DAYTONA_SANDBOX_TTL_MINUTES=30

# ElevenLabs and private TTS cache (server-only)
ELEVENLABS_API_KEY=<your-elevenlabs-api-key>
ELEVENLABS_VOICE_ID=<your-elevenlabs-voice-id>
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
TTS_STORAGE_BUCKET=tts-cache

# TTS storage backend: "supabase" (default) or "r2" (Cloudflare R2)
TTS_STORAGE_BACKEND=supabase

# Cloudflare R2 — only required when TTS_STORAGE_BACKEND=r2 (server-only)
CLOUDFLARE_R2_ACCOUNT_ID=<your-r2-account-id>
CLOUDFLARE_R2_ACCESS_KEY_ID=<your-r2-access-key-id>
CLOUDFLARE_R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
CLOUDFLARE_R2_BUCKET=<your-r2-bucket-name>
R2_ENDPOINT=https://<CLOUDFLARE_R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# TOKEN_VALUE is the Cloudflare R2 public-read token if using signed URLs
TOKEN_VALUE=<your-r2-public-token>
